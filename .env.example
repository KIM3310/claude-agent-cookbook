# Copy to .env and fill in your values. Never commit .env.
# Get your key from https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-...

# Optional — override the default model used by every recipe
# Default: claude-sonnet-4-20250514
CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional — tune client retry behavior
CLAUDE_MAX_RETRIES=3
CLAUDE_TIMEOUT_SECONDS=60

# Optional — structured logging level (DEBUG, INFO, WARNING, ERROR)
COOKBOOK_LOG_LEVEL=INFO

# Optional — where to write structured run artifacts
COOKBOOK_ARTIFACT_DIR=./.artifacts
